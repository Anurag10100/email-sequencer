# ─────────────────────────────────────────────────────────────
# Unipile — connects Gmail/Outlook inboxes and sends outbound mail.
# Get these from https://dashboard.unipile.com
# ─────────────────────────────────────────────────────────────
# DSN looks like  api8.unipile.com:13841  (host:port, NO https://)
UNIPILE_DSN=
# Access token from dashboard.unipile.com → Access Tokens
UNIPILE_API_KEY=

# Safety switch. While true, the backend LOGS sends instead of delivering them.
# Flip to false only when you have connected an inbox and are ready to send for real.
DRY_RUN=true

# Backend port (the Vite dev server proxies /api → here)
PORT=3001

# Where the hosted-auth wizard returns the user after connecting an inbox
FRONTEND_URL=http://localhost:5176
